#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KTLINT_BIN="$SCRIPT_DIR/ktlint"

STAGED_KT_FILES="$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.kt$' || true)"

if [ -z "$STAGED_KT_FILES" ]; then
  exit 0
fi

echo "Checking staged Kotlin files with ktlint..."
HAS_ERRORS=0
if [ -n "$STAGED_KT_FILES" ]; then
  echo "$STAGED_KT_FILES" | xargs -P8 "$KTLINT_BIN" 2>/dev/null || HAS_ERRORS=1
fi
if [ $HAS_ERRORS -ne 0 ]; then
  echo "ktlint: violations found. Run ./tools/formatter/format.sh" >&2
  exit 1
fi
